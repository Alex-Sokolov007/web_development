<!-- <!DOCTYPE html> -->
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device‑width, initial‑scale=1.0" />
  <title>Магазин — Корзина</title>
  <link rel="stylesheet" href="/styles/index.css" />
  <link rel="stylesheet" href="/styles/basket.css" />
</head>
<body>
    <% let sum = 0 %>
    <%- include('blocks/header', status) -%>
  <main class="main">
    <section class="cart">
        <h3>Ваша корзина <%= user.name %> <%= user.otc %></h3>
<% if(products_in_busket.length <= 0){ %>
      <div class="container">
        <h2>Товаров нет</h2>
      </div>
  <% }else{%>
      <div class="container">
          
              <div class="cart-list">
                <!-- Товар 1 -->
                <% for(let i = 0; i<products_in_busket.length; i++){ %>
                <input type="text" hidden name="id_product" form="new_order" value="<%= products_in_busket[i].id_product %>">
                
                  <div class="cart-item">
                  <img src="<%= products_in_busket[i].img %>" alt="Товар 1" />
                  <div class="cart-info">
                    <h4><%= products_in_busket[i].name %></h4>
                    <p class="price"><%= products_in_busket[i].prise %> ₽</p> <input type="number" name="Prise" hidden value="<%= products_in_busket[i].prise %>" form="new_order">
                    <div class="qty">
                      <button class="qty-btn" onclick="
                        const price = document.getElementById('number<%= products_in_busket[i].id_product %>');
                        // price.innerText;
                        if(price.value != 0)
                          price.value -= 1
                        ">−</button>
                      <input type="number" id="number<%= products_in_busket[i].id_product %>" name="quantity" form="new_order" value="<%= products_in_busket[i].number_produxt %>">
                      <button class="qty-btn" 
                      onclick="
                        const price2 = document.getElementById('number<%= products_in_busket[i].id_product %>');
                        if(price2.value != 100)
                          price2.value = Number(price2.value) + 1
                        "
                        
                      >+</button>
                    </div>
                  </div>
                      <form action="/busket" method="post">
                        <input type="text" hidden name="id_product" value="<%= products_in_busket[i].id_product %>">
                        <button class="btn remove-btn" type="submit">Удалить</button>
                      </form>
                  </div>
                </div>
                <% sum += Number(products_in_busket[i].prise) * Number(products_in_busket[i].number_produxt)
              } %>
          

        <div class="cart-total">
          <h4>Итого: <span class="total-amount"><%= sum %>₽</span></h4>
          <form action="/new_order" id="new_order" method="post">
            <input type="text" name="adress" required placeholder="Адресс">
            <input type="number" name="id_busket" hidden value="<%= user.id_user %>">  

            <button class="btn checkout-btn">Оформить заказ</button>
          </form>
        </div>
     
      </div>
      <% } %>
    </section>
  </main>

    <%- include('blocks/footer') -%>

</body>
</html>